# Claude Code local settings
.claude/

# Temporary extraction scripts
tmp-*.php

# Node dependencies — not deployed, only used for build
oz-variations-bcw/node_modules/

# esbuild source maps — dev only, not deployed
oz-variations-bcw/assets/js/*.map
oz-variations-bcw/assets/css/*.map

# One-off tools/scripts — not part of the codebase
tools/

# Design assets & mockups — not code, stored locally only
bucket-labels/
bucket-label-design.html

# Images — never commit binary images to the repo
*.jpeg
*.jpg
*.png
*.gif
*.bmp
*.webp
*.svg
*.ico

# But DO track theme image assets
!oz-theme/img/**
